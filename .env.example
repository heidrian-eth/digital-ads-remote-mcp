# Copy this file to `.env` and fill in the values.
# `.env` is gitignored and must never be committed.

# Google Cloud project hosting the MCP Cloud Run service and Secret Manager entries.
GCP_PROJECT=your-gcp-project

# Secret Manager secret names (just the names — values are fetched via gcloud).
PRIVATE_KEY_SECRET=your-mcp-privatekey-secret
API_KEY_SECRET=your-mcp-apikeys-secret

# Public base URL of the deployed Cloud Run service (no trailing slash).
SERVICE_URL=https://your-mcp-service-xxxxxxxxxxxx.region.run.app
